{
  "$id": "https://schemas.apexops.dev/customization-lock-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "capabilityPacks": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "digest": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "id": {
            "minLength": 1,
            "type": "string"
          },
          "version": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "id",
          "version",
          "digest"
        ],
        "type": "object"
      },
      "type": "array",
      "uniqueItems": true
    },
    "customizationId": {
      "minLength": 1,
      "type": "string"
    },
    "lockedAt": {
      "format": "date-time",
      "type": "string"
    },
    "manifestHash": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "schemaVersion": {
      "const": "1.0.0",
      "type": "string"
    },
    "version": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "customizationId",
    "version",
    "manifestHash",
    "capabilityPacks",
    "lockedAt"
  ],
  "type": "object"
}
