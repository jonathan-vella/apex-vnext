{
  "$id": "https://schemas.apexops.dev/evidence-manifest-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "entries": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "bytes": {
            "minimum": 0,
            "type": "integer"
          },
          "hash": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "kind": {
            "minLength": 1,
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "retention": {
            "anyOf": [
              {
                "const": "immutable",
                "type": "string"
              },
              {
                "const": "project",
                "type": "string"
              },
              {
                "const": "optional",
                "type": "string"
              }
            ]
          }
        },
        "required": [
          "kind",
          "hash",
          "bytes",
          "required",
          "retention"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "projectId": {
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "runId": {
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]{0,127}$",
      "type": "string"
    },
    "schemaVersion": {
      "const": "1.0.0",
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "projectId",
    "runId",
    "createdAt",
    "entries"
  ],
  "type": "object"
}
