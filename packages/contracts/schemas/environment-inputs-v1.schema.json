{
  "$id": "https://schemas.apexops.dev/environment-inputs-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "environment": {
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "inputs": {
      "patternProperties": {
        "^(.*)$": {
          "anyOf": [
            {
              "additionalProperties": false,
              "properties": {
                "kind": {
                  "const": "value",
                  "type": "string"
                },
                "value": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "number"
                    },
                    {
                      "type": "boolean"
                    }
                  ]
                }
              },
              "required": [
                "kind",
                "value"
              ],
              "type": "object"
            },
            {
              "additionalProperties": false,
              "properties": {
                "kind": {
                  "const": "secret-reference",
                  "type": "string"
                },
                "provider": {
                  "anyOf": [
                    {
                      "const": "environment",
                      "type": "string"
                    },
                    {
                      "const": "azure-key-vault",
                      "type": "string"
                    },
                    {
                      "const": "github-actions",
                      "type": "string"
                    }
                  ]
                },
                "reference": {
                  "minLength": 1,
                  "type": "string"
                },
                "version": {
                  "minLength": 1,
                  "type": "string"
                }
              },
              "required": [
                "kind",
                "provider",
                "reference"
              ],
              "type": "object"
            }
          ]
        }
      },
      "type": "object"
    },
    "projectId": {
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "runId": {
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]{0,127}$",
      "type": "string"
    },
    "schemaVersion": {
      "const": "1.0.0",
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "projectId",
    "runId",
    "environment",
    "inputs"
  ],
  "type": "object"
}
