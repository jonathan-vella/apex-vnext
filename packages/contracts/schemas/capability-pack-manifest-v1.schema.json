{
  "$id": "https://schemas.apexops.dev/capability-pack-manifest-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "capabilities": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "digest": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "entrypoints": {
      "patternProperties": {
        "^(.*)$": {
          "minLength": 1,
          "type": "string"
        }
      },
      "type": "object"
    },
    "id": {
      "minLength": 1,
      "type": "string"
    },
    "requires": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "schemaVersion": {
      "const": "1.0.0",
      "type": "string"
    },
    "version": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "version",
    "digest",
    "capabilities",
    "entrypoints",
    "requires"
  ],
  "type": "object"
}
