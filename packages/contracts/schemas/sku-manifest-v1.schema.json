{
  "$id": "https://schemas.apexops.dev/sku-manifest-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "environments": {
      "items": {
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "projectId": {
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "revisions": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "number": {
            "minimum": 1,
            "type": "integer"
          },
          "reason": {
            "minLength": 1,
            "type": "string"
          },
          "sourceHash": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          }
        },
        "required": [
          "number",
          "createdAt",
          "sourceHash",
          "reason"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "schemaVersion": {
      "const": "1.0.0",
      "type": "string"
    },
    "services": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "environment": {
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "type": "string"
          },
          "logicalId": {
            "minLength": 1,
            "type": "string"
          },
          "rationale": {
            "minLength": 1,
            "type": "string"
          },
          "service": {
            "minLength": 1,
            "type": "string"
          },
          "sku": {
            "minLength": 1,
            "type": "string"
          },
          "userPinned": {
            "type": "boolean"
          }
        },
        "required": [
          "logicalId",
          "service",
          "environment",
          "userPinned"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "schemaVersion",
    "projectId",
    "environments",
    "services",
    "revisions"
  ],
  "type": "object"
}
