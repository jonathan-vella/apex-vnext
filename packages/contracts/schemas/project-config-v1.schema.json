{
  "$id": "https://schemas.apexops.dev/project-config-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "createdAt": {
      "format": "date-time",
      "type": "string"
    },
    "defaultIacTool": {
      "anyOf": [
        {
          "const": "bicep",
          "type": "string"
        },
        {
          "const": "terraform",
          "type": "string"
        }
      ]
    },
    "displayName": {
      "minLength": 1,
      "type": "string"
    },
    "projectId": {
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "schemaVersion": {
      "const": "1.0.0",
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "projectId",
    "displayName",
    "createdAt",
    "defaultIacTool"
  ],
  "type": "object"
}
