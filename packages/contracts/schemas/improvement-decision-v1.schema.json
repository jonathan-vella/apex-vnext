{
  "$id": "https://schemas.apexops.dev/improvement-decision-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "actor": {
      "minLength": 1,
      "type": "string"
    },
    "decidedAt": {
      "format": "date-time",
      "type": "string"
    },
    "decision": {
      "anyOf": [
        {
          "const": "accepted",
          "type": "string"
        },
        {
          "const": "rejected",
          "type": "string"
        },
        {
          "const": "deferred",
          "type": "string"
        }
      ]
    },
    "externalRef": {
      "pattern": "^https://github\\.com/[^/]+/[^/]+/(?:issues|pull)/[1-9][0-9]*$",
      "type": "string"
    },
    "projectId": {
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "proposalId": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "rationale": {
      "maxLength": 2048,
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "1.0.0",
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "projectId",
    "proposalId",
    "decidedAt",
    "actor",
    "decision",
    "rationale"
  ],
  "type": "object"
}
