{
  "$id": "https://schemas.apexops.dev/implementation-intent-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "outputs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array"
    },
    "projectId": {
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "resources": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "controls": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array",
            "uniqueItems": true
          },
          "dependsOn": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array",
            "uniqueItems": true
          },
          "id": {
            "minLength": 1,
            "type": "string"
          },
          "purpose": {
            "minLength": 1,
            "type": "string"
          },
          "type": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "id",
          "type",
          "purpose",
          "dependsOn",
          "controls"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "runId": {
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]{0,127}$",
      "type": "string"
    },
    "schemaVersion": {
      "const": "1.0.0",
      "type": "string"
    },
    "sourceHashes": {
      "patternProperties": {
        "^(.*)$": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "required": [
    "schemaVersion",
    "projectId",
    "runId",
    "sourceHashes",
    "resources",
    "outputs"
  ],
  "type": "object"
}
