{
  "$id": "https://schemas.apexops.dev/scenario-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "description": {
      "minLength": 1,
      "type": "string"
    },
    "expectedOutcomes": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "id": {
      "minLength": 1,
      "type": "string"
    },
    "inputs": {
      "patternProperties": {
        "^(.*)$": {}
      },
      "type": "object"
    },
    "schemaVersion": {
      "const": "1.0.0",
      "type": "string"
    },
    "tags": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "title": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "title",
    "description",
    "inputs",
    "expectedOutcomes",
    "tags"
  ],
  "type": "object"
}
