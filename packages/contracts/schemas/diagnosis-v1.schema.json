{
  "$id": "https://schemas.apexops.dev/diagnosis-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "causes": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "confidence": {
            "anyOf": [
              {
                "const": "low",
                "type": "string"
              },
              {
                "const": "medium",
                "type": "string"
              },
              {
                "const": "high",
                "type": "string"
              }
            ]
          },
          "evidenceRefs": {
            "items": {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            "type": "array",
            "uniqueItems": true
          },
          "id": {
            "minLength": 1,
            "type": "string"
          },
          "remediation": {
            "minLength": 1,
            "type": "string"
          },
          "summary": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "id",
          "summary",
          "confidence",
          "evidenceRefs"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "diagnosedAt": {
      "format": "date-time",
      "type": "string"
    },
    "observations": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array"
    },
    "projectId": {
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "type": "string"
    },
    "runId": {
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_-]{0,127}$",
      "type": "string"
    },
    "schemaVersion": {
      "const": "1.0.0",
      "type": "string"
    },
    "status": {
      "anyOf": [
        {
          "const": "healthy",
          "type": "string"
        },
        {
          "const": "degraded",
          "type": "string"
        },
        {
          "const": "failed",
          "type": "string"
        },
        {
          "const": "unknown",
          "type": "string"
        }
      ]
    }
  },
  "required": [
    "schemaVersion",
    "projectId",
    "runId",
    "diagnosedAt",
    "status",
    "observations",
    "causes"
  ],
  "type": "object"
}
