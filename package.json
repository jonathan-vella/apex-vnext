{
  "name": "apex-vnext",
  "version": "0.10.0",
  "description": "Standalone APEX vNext runtime for governed Azure platform engineering workflows.",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "lefthook install",
    "build:vnext": "tsc -b tsconfig.vnext.json",
    "lint:vnext": "tsc -b tsconfig.vnext.json --pretty false",
    "clean:vnext": "tsc -b tsconfig.vnext.json --clean",
    "test:vnext": "npm run prepare:vnext-assets && npm run build:vnext && npm run test --workspaces --if-present",
    "prepare:vnext-assets": "npm run prepare:assets --workspace @apex/cli",
    "validate:vnext": "npm run prepare:vnext-assets && node tools/scripts/validate-vnext.mjs",
    "validate:vnext-live-workflow": "node tools/scripts/validate-vnext-live-workflow.mjs",
    "test:vnext-live-workflow": "node --test tools/tests/vnext-live-prepare.test.mjs tools/tests/vnext-live-workflow.test.mjs tools/tests/vnext-qualification-context.test.mjs",
    "test:vnext-validator": "npm run build --workspace @apex/contracts && node --test tools/tests/vnext/validate-vnext.test.mjs tools/tests/vnext/live-qualification.test.mjs tools/tests/vnext-live-workflow.test.mjs tools/tests/vnext-qualification-context.test.mjs",
    "test:vnext-pack": "node --test tools/tests/vnext/pack-vnext.test.mjs tools/tests/vnext/prepare-assets.test.mjs",
    "pack:vnext": "node tools/scripts/pack-vnext.mjs",
    "qualify:vnext": "npm run validate:vnext && npm run test:vnext && npm run test:vnext-validator && npm run test:vnext-pack",
    "qualify:vnext-release": "node tools/scripts/qualify-vnext-release.mjs",
    "live:vnext": "npm run build --workspace @apex/contracts && node tools/scripts/live-qualification.mjs",
    "prepare:vnext-live": "npm run prepare:vnext-assets && npm run build:vnext && node tools/scripts/vnext-live-prepare.mjs",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "lint:links": "find docs README.md CONTRIBUTING.md CHANGELOG.md -type f -name '*.md' -print | xargs -I {} markdown-link-check {} --config .markdown-link-check.json",
    "validate:docs": "run-p lint:md lint:links lint:docs-freshness",
    "validate:artifacts": "node tools/scripts/validate-artifacts.mjs",
    "fix:artifacts": "node tools/scripts/validate-artifacts.mjs --fix",
    "lint:artifact-templates": "npm run validate:artifacts --",
    "lint:h2-sync": "npm run validate:artifacts --",
    "fix:artifact-h2": "node tools/scripts/validate-artifacts.mjs --fix",
    "check:h2-order": "node tools/scripts/check-h2-order.mjs",
    "check:context-redundancy": "node tools/scripts/check-context-redundancy.mjs",
    "render:headings-summary": "node tools/scripts/render-headings-summary.mjs",
    "validate:headings-summary": "node tools/scripts/validate-headings-summary.mjs && node --test tools/tests/artifact-heading-generation.test.mjs",
    "lint:version-sync": "node tools/scripts/validate-version-sync.mjs",
    "lint:deprecated-refs": "node tools/scripts/validate-no-deprecated-refs.mjs",
    "lint:mcp-config": "node tools/scripts/validate-mcp-config.mjs",
    "validate:extension-bloat": "node tools/scripts/validate-extension-bloat.mjs",
    "lint:docs-freshness": "node tools/scripts/check-docs-freshness.mjs",
    "lint:docs-frontmatter": "node tools/scripts/lint-docs-frontmatter.mjs",
    "validate:agents": "node tools/scripts/validate-agents.mjs",
    "lint:agent-frontmatter": "npm run validate:agents --",
    "lint:vendor-prompting": "node tools/scripts/validate-agents.mjs --only=vendor-prompting",
    "lint:workflow-handoffs": "node tools/scripts/validate-agents.mjs --only=workflow-handoffs",
    "test:vendor-prompting": "node --test tools/tests/vendor-prompting/run.test.mjs",
    "lint:skills-format": "npm run validate:skills --",
    "test:governance-discovery": "python3 -m pytest .github/skills/azure-governance-discovery/scripts/test_discover.py -q",
    "validate:instruction-checks": "node tools/scripts/validate-instruction-checks.mjs",
    "validate:session-state": "node tools/scripts/validate-session-state.mjs",
    "lint:prose": "vale --config .vale.ini docs/ .github/ README.md || echo 'Vale not installed - run: brew install vale'",
    "lint:json": "node tools/scripts/lint-json.mjs",
    "lint:json-schemas": "node tools/scripts/validate-json-schemas.mjs",
    "lint:yaml": "find . \\( -name '*.yml' -o -name '*.yaml' \\) ! -path './node_modules/*' ! -path './infra/*' -exec yamllint -c .yamllint.yml {} \\; 2>/dev/null || echo 'yamllint not installed - run: pip install yamllint'",
    "lint:python": "cd tools/mcp-servers/azure-pricing && python3 -m ruff check src/ tests/ && python3 -m ruff format --check src/ tests/ && cd ../../../tools/apex-recall && python3 -m ruff check src/",
    "lint:python:fix": "cd tools/mcp-servers/azure-pricing && python3 -m ruff check --fix src/ tests/ && python3 -m ruff format src/ tests/ && cd ../../../tools/apex-recall && python3 -m ruff check --fix src/",
    "lint:python:types:warn": "cd tools/mcp-servers/azure-pricing && python3 -m mypy src/ || true",
    "lint:python:security:warn": "cd tools/mcp-servers/azure-pricing && python3 -m bandit -q -r -c pyproject.toml src/ || true",
    "test:apex-recall": "python3 -m pytest tools/tests/test_apex_recall/ -q",
    "test:subagent-file-contract": "node --test tools/tests/subagent-file-contract.test.mjs",
    "test:orphan-skill-discovery": "node --test tools/tests/orphan-skill-discovery.test.mjs",
    "test:sku-manifest": "node --test tools/tests/validate-sku-manifest.test.mjs",
    "test:sku-iac-coverage": "node --test tools/tests/validate-sku-iac-coverage.test.mjs",
    "test:derive-sku-allowlist": "node --test tools/tests/derive-sku-allowlist.test.mjs",
    "lint:safe-shell": "node tools/scripts/safe-shell.mjs",
    "lint:drawio": "node tools/scripts/validate-drawio-files.mjs",
    "lint:terraform-fmt": "terraform fmt -check -recursive infra/terraform/",
    "lint:bicep-fmt": "bash tools/scripts/check-bicep-fmt.sh",
    "validate:terraform": "for dir in infra/terraform/*/; do [ -f \"$dir/main.tf\" ] && (cd \"$dir\" && terraform init -backend=false -input=false > /dev/null 2>&1 && terraform validate) || true; done",
    "validate:vscode": "node tools/scripts/validate-vscode-config.mjs",
    "fetch:deprecations": "node tools/scripts/fetch-azure-deprecations.mjs",
    "snapshot:baseline": "bash tools/scripts/snapshot-agent-context.sh",
    "diff:baseline": "bash tools/scripts/diff-context-baseline.sh",
    "profile:debug-log": "python3 tools/scripts/profile_debug_log.py",
    "assess:agents": "node tools/scripts/assess-agents.mjs",
    "smoke:verify": "python3 tools/scripts/smoke_verify.py",
    "lint:agent-checks": "npm run validate:agents --",
    "lint:glob-audit": "node tools/scripts/validate-glob-audit.mjs",
    "validate:model-consistency": "node tools/scripts/validate-models.mjs --only=consistency",
    "validate:deprecated-models": "node tools/scripts/validate-models.mjs --only=deprecated",
    "generate:model-catalog": "node tools/scripts/generate-model-catalog.mjs",
    "validate:model-catalog": "node tools/scripts/validate-models.mjs --only=catalog",
    "validate:models": "node tools/scripts/validate-models.mjs",
    "validate:skills": "node tools/scripts/validate-skills.mjs",
    "lint:skill-references": "npm run validate:skills --",
    "lint:orphaned-content": "node tools/scripts/validate-orphaned-content.mjs",
    "validate:workflow-graph": "node tools/scripts/validate-workflow-graph.mjs",
    "validate:v1-compatibility-matrix": "node tools/scripts/validate-v1-compatibility-matrix.mjs",
    "validate:vnext-project-controls": "node tools/scripts/validate-vnext-project-controls.mjs",
    "validate:challenger-findings": "node tools/scripts/validate-challenger-findings.mjs",
    "validate:challenger-presence": "node tools/scripts/validate-challenger-presence.mjs",
    "validate:challenger-decisions": "node tools/scripts/validate-challenge-findings-decisions.mjs --all",
    "validate:lens-references": "node tools/scripts/validate-lens-references.mjs",
    "report:challenger-gaps": "node tools/scripts/lessons-to-checklists.mjs",
    "challenger-telemetry": "node tools/scripts/challenger-telemetry.mjs",
    "lint:workflow-table-sync": "node tools/scripts/validate-workflow-table-sync.mjs",
    "validate:skill-checks": "node tools/scripts/validate-skill-checks.mjs",
    "validate:stale-refs": "npm run validate:skills --",
    "lint:model-alignment": "npm run validate:agents --",
    "e2e:validate": "node tools/scripts/validate-e2e-step.mjs all",
    "e2e:benchmark": "node tools/scripts/benchmark-e2e.mjs",
    "e2e:combine": "node tools/scripts/combine-e2e-runs.mjs",
    "export:agent-output-html": "python3 tools/scripts/export-agent-output-html.py",
    "init": "node tools/scripts/init-from-template.mjs",
    "setup": "bash tools/scripts/setup-azure.sh",
    "validate:no-hardcoded-counts": "node tools/scripts/validate-no-hardcoded-counts.mjs",
    "validate:hooks": "node tools/scripts/validate-hooks.mjs",
    "validate:iac-security-baseline": "node tools/scripts/validate-iac-security-baseline.mjs",
    "validate:iac-contract": "node tools/scripts/validate-iac-contract.mjs",
    "validate:iac-contract-consistency": "node tools/scripts/validate-iac-contract-consistency.mjs",
    "validate:avm-versions": "node tools/scripts/validate-avm-module-versions.mjs --mode=local",
    "validate:avm-versions:ci": "node tools/scripts/validate-avm-module-versions.mjs --mode=ci",
    "validate:avm-versions:freeze": "node tools/scripts/validate-avm-module-versions.mjs --mode=freeze",
    "validate:avm-versions:offline": "node tools/scripts/validate-avm-module-versions.mjs --mode=local --no-network",
    "validate:plan-avm-pins": "node tools/scripts/validate-plan-avm-pins.mjs --mode=freeze",
    "validate:plan-avm-pins:local": "node tools/scripts/validate-plan-avm-pins.mjs --mode=local",
    "refresh:avm-module-index": "node tools/scripts/refresh-avm-module-index.mjs",
    "refresh:avm-module-index:dry": "node tools/scripts/refresh-avm-module-index.mjs --no-version-refresh",
    "validate:policy-property-map": "node tools/scripts/validate-policy-property-map.mjs",
    "validate:environment-manifest": "node tools/scripts/validate-environment-manifest.mjs",
    "validate:iac-handoff": "node tools/scripts/validate-iac-handoff.mjs",
    "validate:tool-versions": "node tools/scripts/validate-tool-versions.mjs",
    "measure:baseline": "node tools/scripts/measure-workflow-baseline.mjs",
    "prove:bounded-improvement": "npm run build:vnext && node tools/scripts/prove-bounded-improvement.mjs",
    "test:bounded-improvement": "npm run build:vnext && node --test tools/tests/bounded-improvement-poc.test.mjs",
    "validate:policy-precheck": "node tools/scripts/validate-policy-precheck.mjs",
    "lint:policy-precheck": "npm run validate:policy-precheck --",
    "validate:sku-manifest": "node tools/scripts/validate-sku-manifest.mjs",
    "validate:sku-iac-coverage": "node tools/scripts/validate-sku-iac-coverage.mjs",
    "validate:banned-phrases": "node tools/scripts/validate-banned-phrases.mjs",
    "validate:context-budget": "node tools/scripts/validate-context-budget.mjs",
    "derive:sku-allowlist": "node tools/scripts/derive-sku-allowlist.mjs",
    "validate:terminology": "node tools/scripts/validate-terminology.mjs",
    "build:drawio-icons": "python3 tools/scripts/convert-azure-icons-to-drawio.py",
    "validate:region-canonical": "node tools/scripts/validate-region-canonical.mjs",
    "validate:modernization-ownership": "node tools/scripts/validate-modernization-ownership.mjs",
    "test:modernization-ownership": "node --test tools/tests/validate-modernization-ownership.test.mjs",
    "validate:repository-validator-graph": "node tools/scripts/validate-repository-validator-graph.mjs",
    "test:repository-validator-graph": "node --test tools/tests/validate-repository-validator-graph.test.mjs",
    "validate:github-workflows": "node tools/scripts/validate-github-workflows.mjs",
    "test:github-workflows": "node --test tools/tests/validate-github-workflows.test.mjs",
    "test:retired-automation": "node --test tools/tests/retired-automation.test.mjs",
    "test:hooks": "bash tools/tests/test-hooks.sh",
    "validate:governance-trace": "node tools/scripts/validate-governance-trace.mjs",
    "test:classify-model": "node --test tools/tests/validate-agents/classify-model.test.mjs",
    "test:context-budget": "node --test tools/tests/validate-context-budget.test.mjs",
    "test:models": "node --test tools/tests/validate-models.test.mjs",
    "test:drawio-mcp": "cd tools/mcp-servers/drawio && deno test -P --no-check",
    "test:convert-drawio-icons": "python3 -m pytest tools/tests/test_convert_drawio_icons.py -q",
    "test:azure-pricing-mcp": "tools/mcp-servers/azure-pricing/.venv/bin/python -m pytest tools/mcp-servers/azure-pricing/tests -q",
    "test:lib-json": "node --test tools/tests/lib/json.test.mjs",
    "test:lib-ajv": "node --test tools/tests/lib/ajv-validator.test.mjs",
    "test:registry-validator-reporter": "node --test tools/tests/lib/registry-validator-reporter.test.mjs",
    "test:lib-e2e": "node --test tools/tests/lib/e2e-helpers.test.mjs",
    "test:devcontainer-verdicts": "node --test tools/tests/compare-devcontainer-verdicts.test.mjs",
    "validate:_node": "run-p validate:artifacts validate:agents validate:skills lint:version-sync lint:deprecated-refs lint:mcp-config validate:extension-bloat validate:headings-summary validate:instruction-checks validate:session-state validate:workflow-graph validate:v1-compatibility-matrix validate:vnext-project-controls validate:vnext-live-workflow validate:lens-references validate:challenger-findings validate:challenger-presence lint:workflow-table-sync lint:workflow-handoffs validate:skill-checks lint:json lint:json-schemas lint:glob-audit lint:orphaned-content lint:docs-freshness validate:no-hardcoded-counts validate:hooks validate:context-budget validate:modernization-ownership test:modernization-ownership validate:repository-validator-graph test:repository-validator-graph validate:github-workflows test:github-workflows test:registry-validator-reporter test:retired-automation validate:iac-security-baseline validate:policy-precheck validate:sku-manifest validate:sku-iac-coverage validate:banned-phrases validate:vscode lint:drawio validate:terminology validate:model-consistency validate:deprecated-models validate:model-catalog validate:region-canonical test:classify-model test:devcontainer-verdicts lint:safe-shell validate:tool-versions",
    "validate:_node-ci": "npm run build:vnext && run-p validate:artifacts validate:agents validate:skills lint:version-sync lint:deprecated-refs lint:mcp-config validate:extension-bloat validate:headings-summary validate:instruction-checks validate:session-state validate:workflow-graph validate:v1-compatibility-matrix validate:vnext-project-controls validate:vnext-live-workflow validate:lens-references validate:challenger-findings validate:challenger-presence lint:workflow-table-sync lint:workflow-handoffs validate:skill-checks lint:json lint:json-schemas lint:glob-audit lint:orphaned-content validate:vscode lint:drawio validate:model-consistency validate:deprecated-models validate:model-catalog validate:region-canonical test:classify-model test:devcontainer-verdicts validate:no-hardcoded-counts validate:terminology validate:sku-manifest validate:sku-iac-coverage validate:banned-phrases validate:context-budget validate:modernization-ownership test:modernization-ownership validate:repository-validator-graph test:repository-validator-graph validate:github-workflows test:github-workflows test:registry-validator-reporter test:retired-automation validate:policy-precheck lint:js:ci lint:safe-shell",
    "validate:_external": "run-p lint:md lint:python lint:terraform-fmt lint:bicep-fmt validate:terraform test:apex-recall test:azure-pricing-mcp",
    "validate:all": "run-p --continue-on-error validate:_node validate:_external && echo '✅ All validations passed'",
    "audit:quarterly": "run-p lint:glob-audit lint:orphaned-content lint:docs-freshness",
    "check:azure-icons-freshness": "node tools/scripts/check-azure-icons-freshness.mjs",
    "bench:drawio-quality": "node tools/scripts/run-drawio-quality-bench.mjs",
    "bench:drawio-diff": "node tools/scripts/render-golden-diff.mjs",
    "bench:azure-pricing": "cd tools/mcp-servers/azure-pricing && (./.venv/bin/python tests/fixtures/compact_bench.py 2>/dev/null || python3 tests/fixtures/compact_bench.py)",
    "lint:js": "eslint --cache --cache-location node_modules/.cache/eslint/ --quiet --format=compact",
    "lint:js:warnings": "eslint --cache --cache-location node_modules/.cache/eslint/ --format=compact",
    "lint:js:json": "eslint --cache --cache-location node_modules/.cache/eslint/ --quiet --format=json",
    "lint:js:ci": "npm run lint:js -- --no-cache --max-warnings=0 tools/scripts tools/tests",
    "format": "prettier --write --cache --cache-location node_modules/.cache/prettier-cache --log-level warn .",
    "format:check": "prettier --check --cache --cache-location node_modules/.cache/prettier-cache --log-level warn .",
    "format:bicep": "bash tools/scripts/format-bicep-tree.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-compact": "^9.0.1",
    "eslint-plugin-n": "^18.2.2",
    "fast-xml-parser": "^5.9.3",
    "js-yaml": "^5.2.1",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.10",
    "markdown-link-check": "^3.14.2",
    "markdownlint-cli2": "^0.23.0",
    "npm-run-all2": "^9.0.2",
    "@types/node": "26.1.1",
    "prettier": "^3.9.5",
    "typescript": "7.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jonathan-vella/apex-vnext.git"
  },
  "keywords": [
    "azure",
    "bicep",
    "github-copilot",
    "infrastructure-as-code",
    "agents",
    "agentic",
    "well-architected",
    "azure-verified-modules"
  ],
  "author": "Jonathan Vella",
  "license": "MIT",
  "overrides": {
    "undici": ">=7.24.0",
    "dompurify": ">=3.3.2",
    "nanoid": ">=3.3.8",
    "mermaid": ">=11.4.1",
    "hono": "4.12.29",
    "xmlbuilder2": {
      "js-yaml": "4.3.0"
    }
  },
  "engines": {
    "node": ">=22"
  }
}
